{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cf-pages-test",
  "main": "src/worker.js",
  "compatibility_date": "2026-04-15",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
